    <bpmn:textAnnotation id="TextAnnotation_15cqgj8">
      <bpmn:text>Oltre a Qr  Code ci saranno anche i dati personali e bancari dell'utente</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1ayj05l">
      <bpmn:text>The reservation can be made at most 30 minutes in advance</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0ytod2u">
      <bpmn:text>Il pagamento è andato a buon fine</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0pj9ymy">
      <bpmn:text>non c'erano abbastanza soldi sul conto per coprire il pagamento totale</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0rege2w">
      <bpmn:text>se il conto corente è isufficiente</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_12szkf5">
      <bpmn:text>questo script calcola il prezzo totale anche in base a se la batteria sia &lt;15%</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0ol5cf4">
      <bpmn:text>Se sono passati più di 25 minuti non saranno restituiti  i soldi della cauzione???????</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_02o7stw" associationDirection="None" sourceRef="Event_16i1tvd" targetRef="TextAnnotation_15cqgj8" />
    <bpmn:association id="Association_0v0wzoh" associationDirection="None" sourceRef="Activity_1ma0n6u" targetRef="TextAnnotation_1ayj05l" />
    <bpmn:association id="Association_156e778" associationDirection="None" sourceRef="Event_0iqhf8q" targetRef="TextAnnotation_0ytod2u" />
