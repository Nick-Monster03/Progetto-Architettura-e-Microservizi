<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
    xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" 
    xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" 
    xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" 
    xmlns:di="http://www.omg.org/spec/DD/20100524/DI" 
    xmlns:camunda="http://camunda.org/schema/1.0/bpmn" 
    id="Definitions_rental" 
    targetNamespace="http://bpmn.io/schema/bpmn" 
    exporter="Camunda Modeler" 
    exporterVersion="5.42.0">
  
  <bpmn:process id="rental-process" name="ACME Noleggio Immediato" 
      isExecutable="true" 
      camunda:historyTimeToLive="180">
    
    <!-- START EVENT -->
    <bpmn:startEvent id="StartEvent_Rental" name="Inizio Noleggio">
      <bpmn:outgoing>Flow_toPreAuth</bpmn:outgoing>
    </bpmn:startEvent>
    
    <!-- SEQUENCE FLOW -->
    <bpmn:sequenceFlow id="Flow_toPreAuth" 
        sourceRef="StartEvent_Rental" 
        targetRef="Task_BankPreAuth" />
    
    <!-- SERVICE TASK: Bank Pre-Auth -->
    <bpmn:serviceTask id="Task_BankPreAuth" name="Pre-Autorizzazione Banca" 
        camunda:delegateExpression="${bankPreAuthDelegate}">
      <bpmn:incoming>Flow_toPreAuth</bpmn:incoming>
      <bpmn:outgoing>Flow_toGateway</bpmn:outgoing>
    </bpmn:serviceTask>
    
    <!-- SEQUENCE FLOW -->
    <bpmn:sequenceFlow id="Flow_toGateway" 
        sourceRef="Task_BankPreAuth" 
        targetRef="Gateway_PreAuthCheck" />
    
    <!-- EXCLUSIVE GATEWAY: Check PreAuth Result -->
    <bpmn:exclusiveGateway id="Gateway_PreAuthCheck" name="Fondi Sufficienti?">
      <bpmn:incoming>Flow_toGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_PreAuthFailed</bpmn:outgoing>
      <bpmn:outgoing>Flow_PreAuthSuccess</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    
    <!-- SEQUENCE FLOW: PreAuth Failed -->
    <bpmn:sequenceFlow id="Flow_PreAuthFailed" 
        name="NO" 
        sourceRef="Gateway_PreAuthCheck" 
        targetRef="EndEvent_Failed">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">
        ${preAuthSuccess == false}
      </bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    
    <!-- END EVENT: Failed -->
    <bpmn:endEvent id="EndEvent_Failed" name="Noleggio Fallito">
      <bpmn:incoming>Flow_PreAuthFailed</bpmn:incoming>
    </bpmn:endEvent>
    
    <!-- SEQUENCE FLOW: PreAuth Success -->
    <bpmn:sequenceFlow id="Flow_PreAuthSuccess" 
        name="SÌ (default)" 
        sourceRef="Gateway_PreAuthCheck" 
        targetRef="EndEvent_Success">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">
        ${preAuthSuccess == true}
      </bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    
    <!-- END EVENT: Success -->
    <bpmn:endEvent id="EndEvent_Success" name="Noleggio Avviato">
      <bpmn:incoming>Flow_PreAuthSuccess</bpmn:incoming>
    </bpmn:endEvent>
    
  </bpmn:process>
  
  <!-- BPMN DI (Diagram Visualization) -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="rental-process">
      
      <!-- Start Event -->
      <bpmndi:BPMNShape id="StartEvent_Rental_di" bpmnElement="StartEvent_Rental">
        <dc:Bounds x="179" y="99" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="155" y="142" width="85" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      
      <!-- Task: PreAuth -->
      <bpmndi:BPMNShape id="Task_BankPreAuth_di" bpmnElement="Task_BankPreAuth">
        <dc:Bounds x="270" y="77" width="100" height="80" />
      </bpmndi:BPMNShape>
      
      <!-- Gateway -->
      <bpmndi:BPMNShape id="Gateway_PreAuthCheck_di" bpmnElement="Gateway_PreAuthCheck" isMarkerVisible="true">
        <dc:Bounds x="425" y="92" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="410" y="62" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      
      <!-- End Event: Failed -->
      <bpmndi:BPMNShape id="EndEvent_Failed_di" bpmnElement="EndEvent_Failed">
        <dc:Bounds x="532" y="199" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="509" y="242" width="82" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      
      <!-- End Event: Success -->
      <bpmndi:BPMNShape id="EndEvent_Success_di" bpmnElement="EndEvent_Success">
        <dc:Bounds x="532" y="99" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="509" y="142" width="82" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      
      <!-- Flows -->
      <bpmndi:BPMNEdge id="Flow_toPreAuth_di" bpmnElement="Flow_toPreAuth">
        <di:waypoint x="215" y="117" />
        <di:waypoint x="270" y="117" />
      </bpmndi:BPMNEdge>
      
      <bpmndi:BPMNEdge id="Flow_toGateway_di" bpmnElement="Flow_toGateway">
        <di:waypoint x="370" y="117" />
        <di:waypoint x="425" y="117" />
      </bpmndi:BPMNEdge>
      
      <bpmndi:BPMNEdge id="Flow_PreAuthFailed_di" bpmnElement="Flow_PreAuthFailed">
        <di:waypoint x="450" y="142" />
        <di:waypoint x="450" y="217" />
        <di:waypoint x="532" y="217" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="458" y="177" width="15" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      
      <bpmndi:BPMNEdge id="Flow_PreAuthSuccess_di" bpmnElement="Flow_PreAuthSuccess">
        <di:waypoint x="475" y="117" />
        <di:waypoint x="532" y="117" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="471" y="99" width="66" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
  
</bpmn:definitions>
