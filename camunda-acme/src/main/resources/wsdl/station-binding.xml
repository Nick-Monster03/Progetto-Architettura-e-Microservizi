<jaxws:bindings
  xmlns:jaxws="https://jakarta.ee/xml/ns/jaxws"
  xmlns:wsdl="http://schemas.xmlsoap.org/wsdl/"
  wsdlLocation="StationService.wsdl">

  <jaxws:bindings node="wsdl:definitions/wsdl:portType[@name='StationPort']/wsdl:operation[@name='getAllStations']/wsdl:output">
    <jaxws:parameter
      part="wsdl:definitions/wsdl:message[@name='GetAllStationsResponse']/wsdl:part[@name='body']"
      name="stationsResult"/>
  </jaxws:bindings>

</jaxws:bindings>