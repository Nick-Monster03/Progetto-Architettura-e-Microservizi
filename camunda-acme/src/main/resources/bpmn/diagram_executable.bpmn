    <bpmn:scriptTask id="Activity_0oxpocq" name="Check Cancel Expired" scriptFormat="javascript">
      <bpmn:incoming>Flow_125i7ea</bpmn:incoming>
      <bpmn:outgoing>Flow_1n74wcf</bpmn:outgoing>
      <bpmn:script>var reserveStartTime = execution.getVariable("reserveStartTime");
var elapsedMin = (new Date().getTime() - reserveStartTime) / 60000;

var cancelRetainDeposit = false;
if (elapsedMin &gt; 1.5) {
    cancelRetainDeposit = true;
    print("LATE CANCELLATION (&gt;" + elapsedMin + " min): Deposit will be retained");
} else {
    print("On-time cancellation (" + elapsedMin + " min): Deposit will be refunded");
}

execution.setVariable("cancelisExpired", cancelRetainDeposit);</bpmn:script>
    </bpmn:scriptTask>
