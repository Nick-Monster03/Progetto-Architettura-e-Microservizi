    <bpmn:scriptTask id="Activity_0vvnpw6" name="Check Late Penalty" scriptFormat="javascript">
      <bpmn:incoming>Flow_1jw9lu6</bpmn:incoming>
      <bpmn:outgoing>Flow_0c6gvpy</bpmn:outgoing>
      <bpmn:script>var reserveStartTime = execution.getVariable("reserveStartTime");
var elapsedMin = (new Date().getTime() - reserveStartTime) / 60000;

var latePenalty = 0.0;
if (elapsedMin &gt; 1.5 &amp;&amp; elapsedMin &lt;= 2) {
    latePenalty = 10.0;
    print("LATE PICKUP (" + elapsedMin + " min): €10 penalty will be added at end");
} else {
    print("On-time pickup (" + elapsedMin + " min): No late penalty");
}

execution.setVariable("latePenalty", latePenalty);</bpmn:script>
    </bpmn:scriptTask>
