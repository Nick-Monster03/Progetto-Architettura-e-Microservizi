    <bpmn:textAnnotation id="TextAnnotation_15cqgj8">
      <bpmn:text>Sono visibili solo veicoli disponibili</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1ayj05l">
      <bpmn:text>La prenotazione può essere effettuata massimo 30 minuti prima</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:group id="Group_0sfam0u" />
    <bpmn:textAnnotation id="TextAnnotation_0lxtuci">
      <bpmn:text>Dati di batteria e posizione del veicolo sono sempre disponibili</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1uxgw85">
      <bpmn:text>Ogni 3 minuti</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1eah57o">
      <bpmn:text>Ogni 5 secondi</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0imlkti">
